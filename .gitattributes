# Normalize line endings: LF in the repo, checked out per-platform.
* text=auto eol=lf

# Windows-native scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets (never diff/merge as text)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.jar   binary
*.keystore binary
*.jks   binary
