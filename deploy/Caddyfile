# Caddy reverse proxy + automatic HTTPS for the Fashion OS API.
# API_DOMAIN (from the root .env) decides the cert:
#   api.wearthemood.com -> Caddy auto-provisions a Let's Encrypt cert (recommended)
#   :80                 -> plain HTTP on the droplet IP (testing only; mobile needs HTTPS)
{$API_DOMAIN} {
	encode gzip
	reverse_proxy api:8000
}

# Apex site: landing page + hosted legal docs the app links to (CLAUDE.md §10, §22),
# PLUS the private admin console under an obscure base path. The mobile app talks to
# api.wearthemood.com (separate block above) — it is unaffected by this block.
wearthemood.com, www.wearthemood.com {
	encode gzip

	# Admin console (exact prefix) -> the Next.js standalone container. Keep it out
	# of search indexes; the real security is auth/RBAC inside the app.
	handle /mood-ops-console-7x9* {
		header X-Robots-Tag "noindex, nofollow"
		reverse_proxy admin-web:3000
	}

	# Referral invite redirect (§24): /r/<code> -> the API records the attribution
	# click (mints an opaque token) and 302s to the Google Play listing carrying
	# it as the install `referrer`. Proxied to the API; the API sets no-store so
	# the per-user token is never cached. .well-known/assetlinks.json is served by
	# the static handler below (App Links verification).
	handle /r/* {
		reverse_proxy api:8000
	}

	# Apple App Site Association (iOS Universal Links, §24). The file has NO
	# extension, so set the JSON content-type explicitly; served statically over
	# HTTPS with no redirect (Apple requirements). assetlinks.json (Android) is
	# served by the static handler below with its .json content-type.
	handle /.well-known/apple-app-site-association {
		header Content-Type application/json
		root * /srv/site
		file_server
	}

	# Everything else: the static landing + hosted legal pages + the App Links
	# assetlinks.json + the invite landing page (/invite/) (static serving).
	handle {
		root * /srv/site
		try_files {path} {path}.html {path}/index.html
		file_server
	}
}
