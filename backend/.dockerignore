# Keep the image lean + never bake secrets in.
.venv/
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.env
.env.*
app/tests/
# Keep laptop-run migration/admin scripts out of the image, but DO bake the
# container-run maintenance scripts (they need the worker's runtime + keys).
scripts/*
!scripts/retag_wardrobe.py
requirements-dev.txt
