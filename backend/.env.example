# ─────────────────────────────────────────────────────────────
# Fashion OS — Backend (FastAPI) environment template
# Copy to one of:  .env.dev   .env.staging   .env.prod  (all git-ignored)
# (a bare `.env` is also git-ignored.)  NEVER commit a real env file —
# only this .example. Put real secrets ONLY in your git-ignored .env*.
# ALL AI / 3rd-party SECRET keys live here (backend-only). The app
# never holds them (CLAUDE.md §11).
# The typed config loader that reads these is added with the FastAPI
# skeleton (Step 7).
# ─────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────
ENVIRONMENT=dev                 # dev | staging | prod
APP_NAME=Fashion OS API
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
API_V1_PREFIX=/v1
PORT=8000
# Comma-separated origins allowed by CORS (mobile uses none; web/admin later)
ALLOWED_ORIGINS=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — server only
SUPABASE_JWT_SECRET=your-jwt-secret               # verifies user JWTs (§11)
# Postgres connections (SECRET). Phase 2B:
#  • CONNECTION_STRING = RUNTIME — the 6543 TRANSACTION POOLER (asyncpg pool with
#    statement_cache_size=0). This is the only DSN the app/worker/cron use.
CONNECTION_STRING=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres
#  • CONNECTION_STRING_DIRECT = MIGRATIONS/ADMIN ONLY — the DIRECT 5432 connection,
#    never runtime request traffic. apply_sql.py / apply_all.py prefer this; if it
#    is unset they fall back to CONNECTION_STRING (6543) with a warning.
CONNECTION_STRING_DIRECT=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres



# ── AI providers (SECRET — backend only, CLAUDE.md §2.1) ──────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx
# Per-task models, swappable without code changes:
ANTHROPIC_MODEL_STYLIST=claude-sonnet-4-6
ANTHROPIC_MODEL_ROUTINE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_VISION=claude-sonnet-4-6
ANTHROPIC_MODEL_NEWS=claude-haiku-4-5-20251001
OPENAI_MODEL_CHAT=gpt-4o-mini      # OpenAI fallback for stylist/news/packing text
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Which LLM leads text tasks; the other is the automatic fallback (§2.1). Leave
# 'anthropic' to auto-fall-back to OpenAI when Claude is down/out of credits.
LLM_PRIMARY=anthropic              # anthropic | openai

# ── News ingestion (CLAUDE.md §1 pillar 5) ───────────────────
NEWS_PROVIDER=stub               # stub | rss (rss needs feedparser + feeds below)
# Comma-separated RSS/Atom feed URLs for the fashion news feed. The cron service
# needs feedparser (in requirements.txt). Until set, NEWS_PROVIDER stays stub.
# Validated working set (swap to taste):
# https://www.businessoffashion.com/arc/outboundfeeds/rss/,https://hypebeast.com/feed,https://www.highsnobiety.com/feed/,https://www.vogue.com/feed/rss,https://fashionista.com/.rss/full/
NEWS_RSS_FEEDS=

# ── Shop-the-look affiliate (CLAUDE.md §18, §24) ─────────────
# Unset => links go to a neutral web search (no attribution). Set these once an
# affiliate program is signed up (Amazon Associates, RewardStyle/LTK, Rakuten…).
AFFILIATE_PROVIDER=
AFFILIATE_SEARCH_URL=            # e.g. https://www.retailer.com/search
AFFILIATE_QUERY_PARAM=q
AFFILIATE_TAG_PARAM=             # e.g. tag / utm_source
AFFILIATE_TAG=                   # your affiliate id (backend only)

# ── Subscriptions — RevenueCat (CLAUDE.md §18) ───────────────
# REVENUECAT_API_KEY: secret REST key (optional on-demand verify).
# REVENUECAT_WEBHOOK_AUTH: the exact Authorization value set on the RevenueCat
# webhook — the /v1/billing/webhook endpoint rejects anything that doesn't match.
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_AUTH=

# ── Try-on provider (FASHN.ai at launch — CLAUDE.md §2.2) ─────
TRYON_PROVIDER=stub              # stub | fashn (fashn needs FASHN_API_KEY)
FASHN_API_KEY=your-fashn-key
FASHN_BASE_URL=https://api.fashn.ai
FASHN_MODEL=tryon-v1.6

# ── Background removal (CLAUDE.md §2.2) ──────────────────────
BG_PROVIDER=stub                 # stub | rembg (the Render worker sets rembg)

# ── Push notifications (CLAUDE.md §20) ───────────────────────
PUSH_PROVIDER=stub               # stub | fcm (fcm needs the FCM_* creds below)
DAILY_PUSH_HOUR=8                # local hour (0-23) the morning stylist push fires
# Firebase Cloud Messaging — set on the push/cron service to enable live delivery.
# Needs `pip install firebase-admin`. FCM_CREDENTIALS_JSON is the service-account
# JSON (one line, SECRET). Until set, PUSH_PROVIDER stays effectively 'stub'.
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=

# ── Observability (CLAUDE.md §14) ────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Cost control & limits (CLAUDE.md §12, §14) ───────────────
# One-time free AI try-on trial (total, not per-day). After this, AI needs Premium.
FREE_TRYON_TRIAL_CREDITS=3
DAILY_COST_ALERT_USD=25

# ── Image storage / CDN — Cloudflare R2 (CLAUDE.md §2, §8; INFRA_UPGRADE Ph.1) ─
# S3-compatible. ACCESS keys are SECRET (backend only). Buckets are environment-
# isolated: dev/staging use the *_STAGING buckets so prod images stay separate.
# Until the keys below are real, R2 stays inactive (reads fall back to legacy).
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id            # SECRET
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key    # SECRET
R2_PUBLIC_BUCKET=fashionos-public
R2_PRIVATE_BUCKET=fashionos-private
R2_PUBLIC_BUCKET_STAGING=fashionos-public-staging
R2_PRIVATE_BUCKET_STAGING=fashionos-private-staging
R2_PUBLIC_BASE_URL=https://cdn.wearthemood.com    # CDN custom domain for the PUBLIC bucket
R2_SIGNED_URL_TTL=3600                             # seconds; private GET URLs expire
# Migration write-gate: 'legacy' (default) keeps new images on Supabase Storage;
# 'r2' sends new images to R2. Reads resolve per-record either way. Flip to 'r2'
# ONLY after the 1C backfill + staging verification (INFRA_UPGRADE Phase 1B).
STORAGE_WRITES=legacy                              # legacy | r2

# Nightly DB backup (Phase 4B): pg_dump -> private R2 under backups/<env>/, keep
# the most recent N. Needs CONNECTION_STRING_DIRECT (pg_dump can't use the 6543
# pooler). Runs via the ofelia `backup` cron in docker-compose.
BACKUP_KEEP=7

# ─────────────────────────────────────────────────────────────
# Later phases — placeholders (NOT required for Phase 0)
# ─────────────────────────────────────────────────────────────
# Job queue at scale (CLAUDE.md §7)
# REDIS_URL=redis://localhost:6379/0
# Weather (Open-Meteo needs no key; OpenWeather optional — §2)
# OPENWEATHER_API_KEY=
