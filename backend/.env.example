# ─────────────────────────────────────────────────────────────
# Fashion OS — Backend (FastAPI) environment template
# Copy to one of:  .env.dev   .env.staging   .env.prod  (all git-ignored)
# (a bare `.env` is also git-ignored.)  NEVER commit a real env file —
# only this .example. Put real secrets ONLY in your git-ignored .env*.
# ALL AI / 3rd-party SECRET keys live here (backend-only). The app
# never holds them (CLAUDE.md §11).
# The typed config loader that reads these is added with the FastAPI
# skeleton (Step 7).
# ─────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────
ENVIRONMENT=dev                 # dev | staging | prod
APP_NAME=Fashion OS API
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
API_V1_PREFIX=/v1
PORT=8000
# Comma-separated origins allowed by CORS (mobile uses none; web/admin later)
ALLOWED_ORIGINS=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — server only
SUPABASE_JWT_SECRET=your-jwt-secret               # verifies user JWTs (§11)
# Direct Postgres connection (migrations / pooled access) — SECRET
CONNECTION_STRING=postgresql://postgres.YOUR-PROJECT-REF:YOUR-DB-PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres

# ── AI providers (SECRET — backend only, CLAUDE.md §2.1) ──────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx
# Per-task models, swappable without code changes:
ANTHROPIC_MODEL_STYLIST=claude-sonnet-4-6
ANTHROPIC_MODEL_ROUTINE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_VISION=claude-sonnet-4-6
ANTHROPIC_MODEL_NEWS=claude-haiku-4-5-20251001
OPENAI_MODEL_FALLBACK=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── News ingestion (CLAUDE.md §1 pillar 5) ───────────────────
NEWS_PROVIDER=stub               # stub | rss (rss needs feedparser + feeds below)
# Comma-separated RSS/Atom feed URLs for the fashion news feed. The cron service
# needs feedparser (in requirements.txt). Until set, NEWS_PROVIDER stays stub.
# Validated working set (swap to taste):
# https://www.businessoffashion.com/arc/outboundfeeds/rss/,https://hypebeast.com/feed,https://www.highsnobiety.com/feed/,https://www.vogue.com/feed/rss,https://fashionista.com/.rss/full/
NEWS_RSS_FEEDS=

# ── Try-on provider (FASHN.ai at launch — CLAUDE.md §2.2) ─────
TRYON_PROVIDER=stub              # stub | fashn (fashn needs FASHN_API_KEY)
FASHN_API_KEY=your-fashn-key
FASHN_BASE_URL=https://api.fashn.ai
FASHN_MODEL=tryon-v1.6

# ── Background removal (CLAUDE.md §2.2) ──────────────────────
BG_PROVIDER=stub                 # stub | rembg (the Render worker sets rembg)

# ── Push notifications (CLAUDE.md §20) ───────────────────────
PUSH_PROVIDER=stub               # stub | fcm (fcm needs the FCM_* creds below)
DAILY_PUSH_HOUR=8                # local hour (0-23) the morning stylist push fires
# Firebase Cloud Messaging — set on the push/cron service to enable live delivery.
# Needs `pip install firebase-admin`. FCM_CREDENTIALS_JSON is the service-account
# JSON (one line, SECRET). Until set, PUSH_PROVIDER stays effectively 'stub'.
FCM_PROJECT_ID=
FCM_CREDENTIALS_JSON=

# ── Observability (CLAUDE.md §14) ────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Cost control & limits (CLAUDE.md §12, §14) ───────────────
FREE_DAILY_TRYON_CREDITS=5
DAILY_COST_ALERT_USD=25

# ─────────────────────────────────────────────────────────────
# Later phases — placeholders (NOT required for Phase 0)
# ─────────────────────────────────────────────────────────────
# Storage / CDN (Cloudflare R2 — CLAUDE.md §2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=fashionos
# R2_PUBLIC_BASE_URL=
# Job queue at scale (CLAUDE.md §7)
# REDIS_URL=redis://localhost:6379/0
# Weather (Open-Meteo needs no key; OpenWeather optional — §2)
# OPENWEATHER_API_KEY=
# Subscriptions — RevenueCat entitlement verification (§18)
# REVENUECAT_API_KEY=
# REVENUECAT_WEBHOOK_AUTH=
