# =============================================================================
# admin-web — environment template. Copy to `.env.local` and fill REAL values
# there (git-ignored). NEVER commit secrets. The SUPABASE_SECRET_KEY /
# SERVICE_ROLE key is SERVER-ONLY and must never get a NEXT_PUBLIC_ prefix.
# =============================================================================

# Where the console is mounted (must match the Caddy route in deploy/).
ADMIN_PANEL_BASE_PATH=/mood-ops-console-7x9

# --- Supabase: browser/login client (publishable / anon — safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Prefer the new publishable key when the project has migrated:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy fallback (current project, decision (d) — keep for now):
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase: server-only admin client (bypasses RLS) — NEVER exposed to client
# Prefer the new secret key when migrated:
# SUPABASE_SECRET_KEY=sb_secret_...
# Legacy fallback (current project):
SUPABASE_SERVICE_ROLE_KEY=

# --- FastAPI (used from Phase 7 for push campaigns / refunds; not yet called)
FASTAPI_BASE_URL=https://api.wearthemood.com
FASTAPI_ADMIN_TOKEN=

# --- Optional hardening / Server Actions
ADMIN_IP_ALLOWLIST=
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# --- Cloudflare R2 (used from Phase 6 for seed avatars/posts; not yet called)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
